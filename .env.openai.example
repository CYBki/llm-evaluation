# ============================================================================
# Parallel OpenAI stack config — used by docker-compose.openai.yml
# for A/B comparison against the Qwen (OpenRouter) stack.
#
# Copy to .env.openai and fill in OPENAI_API_KEY (or LLM_API_KEY).
# ============================================================================

# ── Chat LLM: OpenAI ────────────────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
LLM_TIMEOUT_SECONDS=120.0

# ── Model configuration (OpenAI originals) ──────────────────────────────────
STAGE_1_MODEL=gpt-5.2
STAGE_2_MODEL=gpt-4o-mini
RAG_METRICS_MODEL=gpt-5-mini

# ── OpenRouter routing disabled (not used for OpenAI) ───────────────────────
OPENROUTER_PROVIDER_ORDER=
OPENROUTER_REQUIRE_PARAMETERS=false

# ── Pricing (OpenAI originals, USD / 1M token) ──────────────────────────────
STAGE1_INPUT_PRICE=2.50
STAGE1_OUTPUT_PRICE=10.00
STAGE2_INPUT_PRICE=0.15
STAGE2_OUTPUT_PRICE=0.60

# ── Evaluation mode (sync for simpler polling in the compare script) ────────
EVALUATION_MODE=sync
