# ============================================================================
# RAG EVAL API — Production Environment TEMPLATE
# ============================================================================
# UYARI: Bu dosya sadece şablondur. Gerçek .env.prod sunucuda oluşturulmalı.
# ============================================================================

APP_NAME="RAG Eval API"

# Database (production PostgreSQL)
DATABASE_URL=postgresql+psycopg2://PROD_USER:PROD_PASS@PROD_HOST:5432/rageval_prod

# OpenAI
OPENAI_API_KEY=sk-prod-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=120.0

# Models
STAGE_1_MODEL=gpt-5.2
STAGE_2_MODEL=gpt-4o-mini
RAG_METRICS_MODEL=gpt-5-mini

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Evaluation (async for production)
EVALUATION_MODE=async

# CORS (specific origins only)
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Webhook (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=GENERATED_SECRET_HERE
WEBHOOK_TIMEOUT_SECONDS=10.0
WEBHOOK_MAX_RETRIES=3

# Model Pricing
STAGE1_INPUT_PRICE=2.50
STAGE1_OUTPUT_PRICE=10.00
STAGE2_INPUT_PRICE=0.15
STAGE2_OUTPUT_PRICE=0.60

# Prompt Versions
PROMPT_VERSION=v1.0
RUBRIC_VERSION=v1.0
HALLUCINATION_PROMPT_VERSION=v1.0

# Content Limits
MAX_QUESTION_CHARS=8000
MAX_ANSWER_CHARS=40000
MAX_CONTEXT_TOTAL_CHARS=80000
MAX_SINGLE_CONTEXT_CHARS=20000
MAX_GROUND_TRUTH_CHARS=10000

# Runtime (production workers: 2 x CPU + 1)
WEB_CONCURRENCY=4
WEB_TIMEOUT=120

# Celery
CELERY_WORKER_CONCURRENCY=8
CELERY_WORKER_POOL=prefork
CELERY_WORKER_LOGLEVEL=warning
