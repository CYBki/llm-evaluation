# ============================================================================
# RAG EVAL API — Environment Variables Template
# ============================================================================
# Bu dosya tüm gerekli environment variable'ları ve açıklamalarını içerir.
# Kullanım: Bu dosyayı kopyalayıp .env.dev, .env.test, .env.prod oluşturun.
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="RAG Eval API"

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED: PostgreSQL connection string
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/rageval

# ── Chat LLM (OpenAI-compatible: OpenAI, OpenRouter, Azure, vLLM, ...) ───────
# REQUIRED for evaluation (can be empty for smoke tests)
# Legacy OPENAI_API_KEY / OPENAI_BASE_URL names still work (backward-compat).
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TIMEOUT_SECONDS=120.0

# ── Embeddings (optional override) ───────────────────────────────────────────
# When chat is routed via OpenRouter (no embeddings endpoint), pin embeddings
# to OpenAI here. If unset, falls back to LLM_BASE_URL / LLM_API_KEY.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# ── OpenRouter provider routing (used only when LLM_BASE_URL is OpenRouter) ─
# OPENROUTER_REQUIRE_PARAMETERS=true ensures OpenRouter only picks providers
# that support the parameters we send (response_format / json_schema).
# Leave OPENROUTER_PROVIDER_ORDER empty to let OpenRouter auto-pick.
# Pin to a specific provider order only if you have a reason (e.g. latency,
# data residency). Example: OPENROUTER_PROVIDER_ORDER=cerebras,parasail
OPENROUTER_PROVIDER_ORDER=
OPENROUTER_REQUIRE_PARAMETERS=true

# Model configuration
# OpenAI örneği:
#   LLM_BASE_URL=https://api.openai.com/v1
#   STAGE_1_MODEL=gpt-5.2
#   STAGE_2_MODEL=gpt-4o-mini
#   RAG_METRICS_MODEL=gpt-5-mini
# OpenRouter / Qwen (varsayılan):
STAGE_1_MODEL=qwen/qwen3-235b-a22b-2507
STAGE_2_MODEL=qwen/qwen3-32b
RAG_METRICS_MODEL=qwen/qwen3-32b

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Evaluation Mode ──────────────────────────────────────────────────────────
# sync: immediate evaluation (dev/test)
# async: background evaluation via Celery (production)
EVALUATION_MODE=sync

# ── CORS ─────────────────────────────────────────────────────────────────────
# Empty: CORS disabled (most secure)
# "*": Allow all (dev only)
# Comma-separated: "https://app.example.com,https://admin.example.com"
CORS_ORIGINS=

# ── Webhook ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing key for webhook payloads (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=10.0
WEBHOOK_MAX_RETRIES=3

# ── Model Pricing (USD per 1M tokens) ───────────────────────────────────────
# Defaults: Qwen3 via OpenRouter. Override per environment.
STAGE1_INPUT_PRICE=0.20
STAGE1_OUTPUT_PRICE=0.60
STAGE2_INPUT_PRICE=0.10
STAGE2_OUTPUT_PRICE=0.30

# ── Prompt Versions ──────────────────────────────────────────────────────────
PROMPT_VERSION=v1.0
RUBRIC_VERSION=v1.0
HALLUCINATION_PROMPT_VERSION=v1.0

# ── Content Truncation Limits (characters) ──────────────────────────────────
MAX_QUESTION_CHARS=8000
MAX_ANSWER_CHARS=40000
MAX_CONTEXT_TOTAL_CHARS=80000
MAX_SINGLE_CONTEXT_CHARS=20000
MAX_GROUND_TRUTH_CHARS=10000

# ── Production Runtime (Gunicorn) ────────────────────────────────────────────
# Workers: Recommended formula = (2 x CPU) + 1
WEB_CONCURRENCY=4
WEB_TIMEOUT=120

# ── Celery Worker ────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=8
CELERY_WORKER_POOL=prefork
CELERY_WORKER_LOGLEVEL=info
