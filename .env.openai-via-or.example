# ============================================================================
# Third A/B stack (port 8002) — OpenAI models via OpenRouter.
#
# Purpose: isolate pure model-quality difference by removing gateway/provider
# differences between Qwen and OpenAI. The Qwen stack uses OpenRouter; here we
# also route OpenAI models through OpenRouter so both calls share the same
# network hop, rate-limiter and auth flow. Only the model name changes.
#
# Copy to .env.openai-via-or and fill in the OpenRouter key:
#   cp .env.openai-via-or.example .env.openai-via-or
# ============================================================================

# ---- LLM (judge) ----
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_TIMEOUT_SECONDS=120.0

# Same OpenAI models as the direct stack, but called via OpenRouter.
STAGE_1_MODEL=openai/gpt-5.2
STAGE_2_MODEL=openai/gpt-4o-mini
RAG_METRICS_MODEL=openai/gpt-5-mini
SECONDARY_LLM_MODEL=openai/gpt-4o-mini

# Let OpenRouter pick whichever underlying OpenAI provider is cheapest/fastest.
OPENROUTER_PROVIDER_ORDER=

# Approximate pricing (per 1K tokens) — used only for the cost_usd field
# exposed via API. Source: OpenRouter public model pricing.
STAGE_1_INPUT_PRICE_PER_1K=0.005
STAGE_1_OUTPUT_PRICE_PER_1K=0.015
STAGE_2_INPUT_PRICE_PER_1K=0.00015
STAGE_2_OUTPUT_PRICE_PER_1K=0.0006

# ---- Embeddings ----
# OpenRouter doesn't serve embeddings; fall back to OpenAI direct for this one
# call. This is harmless — it doesn't participate in the judge scoring, only
# in cosine-similarity retrieval metrics.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-REPLACE_WITH_OPENAI_KEY
EMBEDDING_MODEL=text-embedding-3-small

# ---- API / rate limits / misc ----
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=dev
EVALUATION_MODE=sync
INGEST_RATE_LIMIT_PER_MIN=60
LOG_LEVEL=INFO
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
